{
  "name": "icd10-finder",
  "version": "0.1.0",
  "description": "Chrome extension: highlight a disease name or keyword to get recommended ICD-10-CM codes via offline semantic (vector) + keyword search.",
  "type": "module",
  "private": true,
  "scripts": {
    "fetch:icd10": "node scripts/fetch-icd10.mjs",
    "fetch:model": "node scripts/fetch-model.mjs",
    "build:embeddings": "node scripts/build-embeddings.mjs",
    "build:data": "npm run fetch:icd10 && npm run fetch:model && npm run build:embeddings",
    "build": "node scripts/build.mjs",
    "dev": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "fflate": "^0.8.2",
    "@types/chrome": "^0.0.287",
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
